# =============================================================================
# 850 Tech Gurus CMS — Environment Variables
# Copy this file to .env.local and fill in all values before running.
# NEVER commit .env.local to version control.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="850 Tech Gurus CMS"

# --- Admin credentials (change before going live) ---
# These are used server-side only to validate login.
ADMIN_EMAIL=admin@850techgurus.com
ADMIN_PASSWORD_HASH=                # bcrypt hash of your admin password
ADMIN_TOTP_SECRET=                  # generate with: node -e "const {authenticator}=require('otplib');console.log(authenticator.generateSecret())"

# --- Client auth secret (JWT / session signing key) ---
AUTH_SECRET=                        # run: openssl rand -base64 32

# --- Database (if/when you connect one) ---
DATABASE_URL=

# --- Email (for notifications, password resets, etc.) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="850 Tech Gurus CMS <noreply@850techgurus.com>"

# --- Storage (UploadThing) ---
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
